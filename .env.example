# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Application Settings
CHUNK_SIZE=125
MAX_WORKERS=4
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Database Settings
